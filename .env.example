# ============================================================
# IRONCLAD RAG BACKEND — Environment Variables
# Copy this to .env for local dev, set these in Railway dashboard for prod
# ============================================================

# OpenAI — Required for embedding generation and AI chat
OPENAI_API_KEY=sk-...

# Optional: Override the chat model (default: gpt-4o-mini)
# Use gpt-4o for best quality, gpt-4o-mini for lower cost
OPENAI_CHAT_MODEL=gpt-4o-mini

# Supabase — Use the SERVICE ROLE key (not anon key) for backend writes
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Security — API key required to POST to /ingest routes
# Generate with: openssl rand -hex 32
INGEST_API_KEY=generate-a-strong-random-key-here

# CORS — Comma-separated list of allowed Next.js origins
# Leave empty during local dev to allow all origins
ALLOWED_ORIGINS=https://your-ironclad-app.vercel.app,http://localhost:3000

# Server
NODE_ENV=production
PORT=3001
